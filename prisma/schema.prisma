// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  price       Float
  category    String
  contactInfo String
  createdAt   DateTime @default(now())
}
